# Copiar a .env y completar. .env NUNCA se versiona (.gitignore).
DJANGO_SECRET_KEY=cambiar-por-una-clave-larga-aleatoria
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Segundo factor (2FA TOTP). Por defecto activado (=1). Poner 0 lo desactiva
# temporalmente (fase de pruebas). Reactivar (=1) antes de clientes reales.
# DJANGO_EXIGIR_2FA=1
# Autoservicio de creación de empresas. Por defecto apagado (=0: solo el
# superusuario crea empresas). Poner 1 permite que cualquier usuario cree la
# suya (fase de pruebas); cerrar volviendo a 0.
# DJANGO_PERMITIR_CREAR_EMPRESAS=0
# sqlite por defecto; para PostgreSQL: postgres://usuario:clave@localhost:5432/auxiliar
# DATABASE_URL=
# Integraciones (fase 1)
# ALEGRA_EMAIL=
# ALEGRA_TOKEN=
# IA de visión para foto de factura (P1.10) — key gratuita en build.nvidia.com
# NVIDIA_API_KEY=
# IA_VISION_URL=https://integrate.api.nvidia.com/v1
# IA_VISION_MODELO=nvidia/nemotron-nano-12b-v2-vl  (ganador del torneo jul 2026)
# Asistente normativo (RAG): usa la misma NVIDIA_API_KEY
# IA_EMBED_MODELO=nvidia/nv-embedqa-e5-v5
# IA_ASISTENTE_MODELO=meta/llama-3.1-8b-instruct  (rápido; ganó el benchmark jul 2026)
# Carpeta de soportes subidos (por defecto app/media/)
# DJANGO_MEDIA_ROOT=
# --- Producción (VPS Docker; ver docker-compose.yml en la raíz) ---
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=tu-ip-o-dominio
# DJANGO_CSRF_ORIGINS=https://tu-dominio   (solo si hay https)
# DJANGO_TRAS_PROXY=1   (si hay proxy inverso con https delante de la app)
# Correo saliente (alertas, recordatorios de cobro, invitaciones, recuperación).
# En desarrollo se imprime en consola.
#
# Producción con Office 365 vía Microsoft Graph (OAuth2 app-only — no depende
# de SMTP AUTH ni Security Defaults; es lo recomendado para servidores).
# Requiere registrar una app en Azure AD con permiso de APLICACIÓN Mail.Send
# y consentimiento de administrador. El remitente sale de DJANGO_FROM_EMAIL.
# DJANGO_EMAIL_BACKEND=core.email_graph.GraphEmailBackend
# MS_GRAPH_TENANT_ID=id-del-directorio-tenant
# MS_GRAPH_CLIENT_ID=id-de-la-aplicacion-cliente
# MS_GRAPH_CLIENT_SECRET=secreto-de-cliente-de-la-app
# DJANGO_FROM_EMAIL=Auxiliar Contable <apoyo@learnway.co>
#
# Alternativa SMTP (solo si el tenant permite SMTP AUTH / Basic Auth):
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.office365.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_USE_TLS=1
# DJANGO_EMAIL_HOST_USER=apoyo@learnway.co
# DJANGO_EMAIL_HOST_PASSWORD=clave-o-app-password-del-buzon
# DJANGO_FROM_EMAIL=Auxiliar Contable <apoyo@learnway.co>
# PostgreSQL (el compose arma DATABASE_URL con estas; pon una contraseña fuerte):
# POSTGRES_PASSWORD=una-contrasena-larga-de-base-de-datos
# POSTGRES_DB=auxiliar
# POSTGRES_USER=auxiliar
